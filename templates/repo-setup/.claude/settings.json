{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "extraKnownMarketplaces": {
    "decode": {
      "source": {
        "source": "github",
        "repo": "implicitdiagnosticsandsolutions/decode-claude-wiki"
      }
    }
  },
  "enabledPlugins": {
    "decode-base@decode": true
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-env-writes.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/reviewer-stop.sh"
          }
        ]
      }
    ]
  }
}
