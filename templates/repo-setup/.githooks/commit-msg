#!/usr/bin/env bash
#
# DECODE commit-msg gate — reviewer marker check + strong override detection.
#
# Git invokes this hook AFTER the commit message is written, passing the
# message file path as $1. Unlike pre-commit, we can reliably read the
# intended commit message here.
#
# Gate logic:
#   - If no substantive files changed: pass.
#   - Else if .claude/.reviewer-clean exists with SHA matching current HEAD: pass.
#   - Else if commit message contains [override-reviewer: <reason>]: pass (logged).
#   - Else: fail with a clear message explaining how to run the reviewer.

set -euo pipefail

COMMIT_MSG_FILE="${1:-}"
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  echo >&2 "[commit-msg] ERROR: expected commit message file as \$1 (got '$COMMIT_MSG_FILE')"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ignore merge commits, squash messages, revert templates — these are
# generated by git, not author-written.
if echo "$COMMIT_MSG" | head -1 | grep -qE '^(Merge|Revert) '; then
  exit 0
fi

# ----- Detect substantive changes -----
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR || true)
SUBSTANTIVE_PATTERN='\.(py|ts|tsx|js|jsx|R|r|java|sql)$|^scripts/|^output/|^dist/'
SUBSTANTIVE_FILES=""
if [ -n "$STAGED_FILES" ]; then
  SUBSTANTIVE_FILES=$(echo "$STAGED_FILES" | grep -E "$SUBSTANTIVE_PATTERN" || true)
fi

if [ -z "$SUBSTANTIVE_FILES" ]; then
  # Nothing substantive — commit-msg gate has nothing to enforce
  exit 0
fi

# ----- Strong override detection -----
# Format: [override-reviewer: reason] anywhere in the commit message.
# Visible forever in `git log --grep="override-reviewer"`.
OVERRIDE_REGEX='\[override-reviewer:[[:space:]]*[^]]+\]'
if echo "$COMMIT_MSG" | grep -qE "$OVERRIDE_REGEX"; then
  echo >&2 "[commit-msg] override-reviewer present — gate bypassed."
  echo >&2 "[commit-msg] This bypass is logged forever in git history."
  exit 0
fi

# ----- Reviewer marker check -----
MARKER="$REPO_ROOT/.claude/.reviewer-clean"
if [ -f "$MARKER" ]; then
  MARKED_SHA=$(awk 'NR==1 {print $1}' "$MARKER" 2>/dev/null || echo "")
  CURRENT_HEAD=$(git rev-parse HEAD 2>/dev/null || echo "initial")
  if [ "$MARKED_SHA" = "$CURRENT_HEAD" ]; then
    # Fresh marker — allow
    exit 0
  fi
fi

# ----- No marker, no override → block -----
cat >&2 <<EOF
================================================================
DECODE COMMIT-MSG GATE: reviewer marker missing or stale.

This commit touches substantive files:
$(echo "$SUBSTANTIVE_FILES" | sed 's/^/  - /')

To proceed, ONE of:
  (a) Run the reviewer subagent this session.
      In Claude Code, ask: "dispatch the reviewer subagent".
      The reviewer writes .claude/.reviewer-clean if no blocking issues.
      Then re-run the commit.
  (b) Override with a reason in the commit message:
      git commit -m "... [override-reviewer: quick doc typo]"
      Overrides are visible forever in \`git log --grep="override-reviewer"\`.

See decode-claude-wiki/docs/rules for rule 03 (reviewer required).
================================================================
EOF
exit 1
