#!/usr/bin/env bash
#
# DECODE pre-commit gate — thin wrapper around the shared language gate.
#
# Split from commit-msg to match git hook semantics:
# - pre-commit: runs before message is written. Cannot read commit message.
#               Runs language lint + artifact-suspicion checks.
# - commit-msg: runs after message is written. Reads message from $1.
#               Runs reviewer-marker check and override detection.
#
# The actual gate logic lives in scripts/language-gate.sh so CI and local
# hooks execute the same checks.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ ! -x "scripts/language-gate.sh" ]; then
  echo >&2 "[gate] ERROR: scripts/language-gate.sh not found or not executable"
  exit 1
fi

exec bash scripts/language-gate.sh
